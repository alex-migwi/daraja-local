{
  "name": "daraja-local",
  "version": "0.1.0",
  "description": "Local emulator for Safaricom Daraja APIs.",
  "type": "module",
  "bin": {
    "daraja-local": "./dist/src/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts start",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/cli/index.js start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "commander": "^12.1.0",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
