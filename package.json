{
  "name": "daraja-local",
  "version": "0.1.0",
  "description": "An unofficial Local emulator for Safaricom Daraja APIs. Develop and test M-PESA integrations locally.",
  "author": {
    "name": "Job Alex Muturi",
    "email": "alex.migwi@gmail.com"
  },
  "type": "module",
  "bin": {
    "daraja-local": "./dist/src/cli/index.js"
  },
  "files": [
    "dist/src",
    "docs/compatibility.md",
    "README.md",
    "how-to",
    "images/daraja-local-poster.png",
    "openapi"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts start",
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/cli/index.js start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "commander": "^12.1.0",
    "fastify": "^5.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
